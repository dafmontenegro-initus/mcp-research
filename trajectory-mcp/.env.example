# --- Meetings DB ---
MEET_DB_HOST=
MEET_DB_PORT=3306
MEET_DB_USER=
MEET_DB_PASSWORD=

# --- Wrike DB ---
WK_DB_HOST=
WK_DB_PORT=3306
WK_DB_USER=
WK_DB_PASSWORD=

# --- BambooHR (public feed URLs, no auth needed) ---
BAMBOOHR_TIMEOFF_URL=
BAMBOOHR_BIRTHDAYS_URL=
BAMBOOHR_ANNIVERSARIES_URL=
BAMBOOHR_HOLIDAYS_URL=

# --- S3 (meeting transcripts — VTT files) ---
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- S3 (Wrike embedding pickles) ---
S3_WRIKE_BUCKET=

# --- RAG service (local FastAPI — start with: cd rag_service && python3 app.py) ---
RAG_SERVICE_URL=http://localhost:8090
# Comma-separated company IDs to pre-warm at RAG service startup (avoids cold-start delays)
WARMUP_COMPANIES=NWN
WARMUP_ENVIRONMENT=prod

# --- Ollama (local LLM — transcript summarization) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SUMMARIZE_MODEL=qwen3.6:27b
