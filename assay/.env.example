MCP_URL=http://localhost:8080
MCP_TOKEN=traj_<get from: cd ../trajectory-mcp && python3 manage_users.py token daniel.montenegro@initus.io>
OLLAMA_URL=http://localhost:11434

# Generator: produces 8-12 adversarial test cases per tool
MODEL=qwen3.6:27b

# Jury: 3 independent judges from different organizations (DeepSeek AI, Google DeepMind,
# IBM Research). Equal size (~8-12B) → comparable votes. All must be pulled locally.
# A result passes only if BOTH the generator-judge (Layer 1) AND the jury majority
# (Layer 2, ≥2/3) approve. Verdicts are binary: pass or fail.
JUDGE_MODELS=deepseek-r1:8b,gemma3:12b,granite4.1:8b
JUDGE_QUORUM=2

# Parallel workers — each opens its own MCP session. Ollama serializes LLM calls,
# but MCP I/O overlaps across workers. Safe to set as high as the number of tools.
MAX_WORKERS=8
